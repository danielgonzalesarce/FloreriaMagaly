rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: arrangements
    // Fields:
    //   - name: string (required)
    //   - description: string
    //   - price: number (required)
    //   - imageUrl: string (required)
    //   - category: string
    //   - active: boolean (required)
    //   - createdAt: timestamp
    //
    // Collection: users
    // Fields:
    //   - email: string (required)
    //   - role: string (required, ['admin', 'user'])
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        request.auth.token.email == "daniel.gonzales.a@tecsup.edu.pe";
    }

    function isValidArrangement(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.imageUrl is string && data.imageUrl.size() < 1000 &&
             data.active is bool &&
             (!('description' in data) || (data.description is string && data.description.size() < 1000)) &&
             (!('category' in data) || (data.category is string && data.category.size() < 50));
    }

    function isValidUser(data) {
      return data.email is string && data.email.size() < 100 &&
             data.role in ['admin', 'user'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /arrangements/{arrangementId} {
      // Publicly readable if active
      allow read: if resource.data.active == true || isAdmin();
      
      // Only admins can write
      allow create: if isAdmin() && isValidArrangement(request.resource.data);
      allow update: if isAdmin() && isValidArrangement(request.resource.data);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      // Users can read their own profile
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      // Only admins can create/update users, or a user can create their own 'user' profile if it doesn't exist
      allow create: if isAuthenticated() && (
        (request.auth.uid == userId && request.resource.data.role == 'user' && request.resource.data.email == request.auth.token.email) ||
        isAdmin()
      ) && isValidUser(request.resource.data);
      
      allow update: if isAdmin() && isValidUser(request.resource.data);
    }
  }
}
